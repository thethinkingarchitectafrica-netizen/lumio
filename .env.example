# .env.example
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control

# ============================================
# GOOGLE AI / GEMINI
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# SUPABASE PROJECT 1 - VECTOR STORE
# ============================================
SUPABASE_VECTOR_URL=https://your-vector-project.supabase.co
SUPABASE_VECTOR_ANON_KEY=your_vector_anon_key_here
SUPABASE_VECTOR_SERVICE_KEY=your_vector_service_key_here

# ============================================
# SUPABASE PROJECT 2 - USER DATABASE
# ============================================
SUPABASE_USER_URL=https://your-user-project.supabase.co
SUPABASE_USER_ANON_KEY=your_user_anon_key_here
SUPABASE_USER_SERVICE_KEY=your_user_service_key_here

# ============================================
# TELEGRAM ALERTS
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ============================================
# APPLICATION SETTINGS
# ============================================
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# RATE LIMITING
# ============================================
GEMINI_RPM_LIMIT=15
GEMINI_RPD_LIMIT=1500

# ============================================
# CACHE SETTINGS
# ============================================
CACHE_TTL_DAYS=7

# ============================================
# MEMORY SETTINGS
# ============================================
MEM0_WRITE_VERIFICATION=true
MEMORY_FALLBACK_ENABLED=true

# ============================================
# MONITORING
# ============================================
SELF_PING_INTERVAL_SECONDS=240
HEALTH_CHECK_ENDPOINT=/health
